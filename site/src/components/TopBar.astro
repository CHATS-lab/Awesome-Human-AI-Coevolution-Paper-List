---
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE, REPO_URL, MAIN_SITE_URL } from '../lib/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Same bar as the main site. This deployment IS the browseable index, so
// "Browse" is local; everything else points back to the main site. "Paper"
// will point to the arXiv preprint once it is public.
const navItems = [
  { href: `${base}/`,                label: 'Browse' },
  { href: `${MAIN_SITE_URL}/stats/`, label: 'Stats' },
  { href: `${MAIN_SITE_URL}/blog/`,  label: 'Blog' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<div class="border-b border-paper-300 dark:border-ink-600 bg-paper-100 dark:bg-nightbg">
  <div class="mx-auto max-w-[960px] px-6 min-h-14 py-2 md:py-0 flex flex-wrap md:flex-nowrap items-center gap-x-4 md:gap-x-7 gap-y-1">
    <a href={MAIN_SITE_URL} class="flex items-center gap-2.5 group shrink-0">
      <span class="grid place-items-center w-7 h-7 rounded-[8px] bg-accent dark:bg-accent-dark text-paper-50 dark:text-nightbg font-display text-[16px] font-semibold leading-none select-none">H</span>
      <span class="font-display text-[16px] font-medium tracking-tight text-ink-700 dark:text-ink-50 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">Human–AI Coevolution</span>
    </a>

    <nav class="flex order-last w-full md:order-none md:w-auto items-baseline gap-[18px] md:gap-5">
      <span class="font-mono text-[12px] uppercase tracking-[0.12em] text-ink-300 dark:text-ink-500 cursor-default select-none" title="Preprint in preparation">Paper · soon</span>
      {navItems.map((item) => {
        const active = item.href === `${base}/`
          ? (currentPath === base || currentPath === `${base}` || currentPath === '')
          : currentPath === item.href.replace(/\/$/, '');
        return (
          <a
            href={item.href}
            class={`font-mono text-[12px] uppercase tracking-[0.12em] transition-colors ${
              active
                ? 'text-accent dark:text-accent-dark underline underline-offset-[5px] decoration-accent dark:decoration-accent-dark'
                : 'text-ink-500 dark:text-ink-300 hover:text-ink-700 dark:hover:text-ink-50'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="ml-auto flex items-center gap-3.5 sm:gap-5">
      <a
        href={`${REPO_URL}/issues/new`}
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex items-center rounded-[8px] border border-accent dark:border-accent-dark px-2.5 py-1.5 font-mono font-semibold text-[12px] uppercase tracking-[0.12em] text-accent dark:text-accent-dark hover:bg-accent hover:text-paper-50 dark:hover:bg-accent-dark dark:hover:text-nightbg transition-colors"
      >
        Add a paper
      </a>

      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener"
        class="text-ink-500 dark:text-ink-300 hover:text-ink-700 dark:hover:text-ink-50 transition-colors"
        aria-label="View on GitHub"
      >
        <svg viewBox="0 0 16 16" width="17" height="17" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
      </a>

      <ThemeToggle />
    </div>
  </div>
</div>
