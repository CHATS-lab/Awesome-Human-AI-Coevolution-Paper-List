---
import Base from '../layouts/Base.astro';
import PaperCard from '../components/PaperCard.astro';
import { loadAllPapers } from '../lib/parsePapers';
const { adjacent } = loadAllPapers();
---
<Base
  title="Adjacent papers — supporting context for human-AI coevolution"
  description="Non-canonical entries that materially inform human-AI coevolution research: foundational RLHF method papers, single-direction behavioral studies, related theoretical frameworks."
>
  <section class="mx-auto max-w-5xl px-6 pt-14 pb-16 reveal-stagger">
    <p class="heading-eyebrow">Adjacent</p>
    <h1 class="display-lg mt-5 text-ink-700 dark:text-ink-50">Adjacent papers</h1>
    <p class="text-ink-600 dark:text-ink-200 mt-4 max-w-2xl text-[15px] leading-relaxed">
      <strong class="text-ink-700 dark:text-ink-50">Non-canonical</strong> entries — useful supporting context like foundational RLHF method papers, single-direction behavioral studies that later inform coevolution work, and related theoretical frameworks. They are intentionally excluded from the main browse, the stats, and the per-category groupings.
    </p>
    <p class="font-mono text-[11px] uppercase tracking-[0.08em] text-ink-400 dark:text-ink-300 mt-4 tabular-nums">{adjacent.length} entries</p>

    <ul class="mt-10 grid gap-4 list-none p-0">
      {adjacent.map((p) => (
        <li><PaperCard paper={p} /></li>
      ))}
    </ul>
  </section>
</Base>
