---
import Base from '../layouts/Base.astro';
import StatsCharts from '../islands/StatsCharts';
import { loadAllPapers } from '../lib/parsePapers';
const { canonical } = loadAllPapers();
const lite = canonical.map((p) => ({
  slug: p.slug, title: p.title, link: p.link,
  authors: p.authors, institutions: p.institutions,
  date: p.date, dateISO: p.dateISO, year: p.year, month: p.month,
  publisher: p.publisher, envs: p.envs, phase: p.phase, keywords: p.keywords,
  tldr: p.tldr, arxivId: p.arxivId, source: p.source, sourceLine: p.sourceLine,
  bibtex: p.bibtex, bibtexConfirmed: p.bibtexConfirmed, sources: p.sources,
}));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base
  title="Statistics — human-AI coevolution research"
  description={`Quarterly publication trends, top keywords, category splits, top institutions and authors across ${canonical.length}+ papers.`}
>
  <article class="mx-auto max-w-[1180px] px-6 pt-14 pb-20 reveal-stagger">

    <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] gap-x-16 gap-y-8">

      <aside class="lg:border-r border-paper-300 dark:border-ink-600 lg:pr-6">
        <p class="meta-label">Page</p>
        <p class="kicker mt-2 text-ink-700 dark:text-ink-50">Statistics</p>
        <p class="mt-6 text-[12.5px] text-ink-500 dark:text-ink-300 leading-relaxed max-w-[14em]">
          Canonical entries only. Adjacent papers are excluded so the picture stays scoped.
        </p>
      </aside>

      <div>
        <p class="heading-eyebrow">Statistics</p>
        <h1 class="kicker-lg mt-5 text-ink-700 dark:text-ink-50">
          Trends across <span class="font-mono tabular-nums">{canonical.length}</span> papers
        </h1>

        <div class="mt-10">
          <StatsCharts client:only="solid-js" papers={lite} basePath={base} />
          <noscript>
            <p class="text-[14px] text-ink-500 dark:text-ink-200">
              Interactive charts need JavaScript. You can still browse the full list on the
              <a class="a-text" href={`${base}/papers`}>papers page</a>.
            </p>
          </noscript>
        </div>
      </div>
    </div>
  </article>
</Base>
