---
import Base from '../../layouts/Base.astro';
import { loadAllPapers, type Paper } from '../../lib/parsePapers';
import { ENV_EMOJI, PHASE_CODE, PHASE_HEADINGS, REPO_URL } from '../../lib/site';
import { normalizePublisher, bibtexVenueKind } from '../../lib/venues';

interface RelatedLite {
  slug: string;
  title: string;
  date: string;
  publisher: string;
}

export async function getStaticPaths() {
  const { canonical, adjacent } = loadAllPapers();
  const all = [...canonical, ...adjacent];

  // Pre-compute related papers per paper at build time, keep slim.
  const related = new Map<string, RelatedLite[]>();
  for (const target of all) {
    const kwSet = new Set(target.keywords);
    const envSet = new Set(target.envs);
    const scored = canonical
      .filter((p) => p.slug !== target.slug)
      .map((p) => {
        let kw = 0;
        for (const k of p.keywords) if (kwSet.has(k)) kw++;
        let env = 0;
        for (const e of p.envs) if (envSet.has(e)) env++;
        return { p, score: kw * 2 + env };
      })
      .filter((x) => x.score >= 2)
      .sort((a, b) => b.score - a.score || (a.p.dateISO < b.p.dateISO ? 1 : -1))
      .slice(0, 6)
      .map((x) => ({
        slug: x.p.slug, title: x.p.title, date: x.p.date, publisher: x.p.publisher,
      }));
    related.set(target.slug, scored);
  }

  return all.map((p) => ({
    params: { slug: p.slug },
    props: { paper: p, related: related.get(p.slug) ?? [] },
  }));
}

const { paper, related } = Astro.props as { paper: Paper; related: RelatedLite[] };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteOrigin = (Astro.site ?? new URL('https://human-ai-coevolution.github.io')).toString().replace(/\/$/, '');
const detailUrl = `${siteOrigin}${base}/papers/${paper.slug}/`;

const tldrFallback = `${paper.title} — ${paper.publisher}, ${paper.date}. Authors: ${paper.authors.slice(0, 5).join(', ')}${paper.authors.length > 5 ? ', et al.' : ''}.`;
const seoDescription = (paper.tldr || tldrFallback).slice(0, 300);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ScholarlyArticle',
    headline: paper.title,
    name: paper.title,
    abstract: paper.tldr || undefined,
    url: detailUrl,
    sameAs: [paper.link, ...(paper.arxivId ? [`https://arxiv.org/abs/${paper.arxivId}`] : [])],
    datePublished: paper.dateISO,
    inLanguage: 'en',
    author: paper.authors.map((name) => ({ '@type': 'Person', name })),
    publisher: paper.publisher
      ? { '@type': 'Organization', name: paper.publisher }
      : undefined,
    keywords: [...paper.envs, ...paper.keywords].join(', ') || undefined,
    isPartOf: {
      '@type': 'DataCatalog',
      name: 'Human-AI Coevolution Paper List',
      url: `${siteOrigin}${base}/`,
    },
    mainEntityOfPage: detailUrl,
    identifier: paper.arxivId ? `arXiv:${paper.arxivId}` : undefined,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Human-AI Coevolution Papers', item: `${siteOrigin}${base}/` },
      { '@type': 'ListItem', position: 2, name: 'Browse', item: `${siteOrigin}${base}/` },
      { '@type': 'ListItem', position: 3, name: paper.title, item: detailUrl },
    ],
  },
];

function bibKey(p: Paper): string {
  const lastName = (p.authors[0] ?? 'unknown').split(/\s+/).pop()!.toLowerCase().replace(/[^a-z]/g, '') || 'anon';
  const titleWord = p.title.split(/\s+/).find((w) => w.length > 3)?.toLowerCase().replace(/[^a-z0-9]/g, '') ?? 'paper';
  const year = p.year > 0 ? p.year : '';
  return `${lastName}${year}${titleWord}`;
}
function escBib(s: string): string {
  return s.replace(/\\/g, '\\textbackslash ').replace(/([&%$#_{}])/g, '\\$1').replace(/~/g, '\\~{}').replace(/\^/g, '\\^{}');
}
function buildBib(p: Paper): string {
  // Prefer the entry's stored bibtex (auto-generated migration output,
  // optionally hand-corrected with bibtex_confirmed: true).
  if (p.bibtex && p.bibtex.trim()) return p.bibtex;
  return synthesizeBib(p);
}

function synthesizeBib(p: Paper): string {
  const key = bibKey(p);
  const authors = p.authors.length > 0 ? p.authors.map(escBib).join(' and ') : 'Unknown';
  const titleEsc = escBib(p.title);
  const year = p.year > 0 ? String(p.year) : '';
  const venue = normalizePublisher(p.publisher);
  const kindLabel = bibtexVenueKind(p.publisher);

  const f: Array<[string, string]> = [];
  f.push(['title', `{${titleEsc}}`]);
  f.push(['author', `{${authors}}`]);
  if (year) f.push(['year', `{${year}}`]);
  let kind = '@inproceedings';
  if (kindLabel === 'misc' && p.arxivId) {
    kind = '@misc';
    f.push(['eprint', `{${p.arxivId}}`]);
    f.push(['archivePrefix', `{arXiv}`]);
    f.push(['url', `{https://arxiv.org/abs/${p.arxivId}}`]);
  } else if (kindLabel === 'misc') {
    kind = '@misc';
    f.push(['howpublished', `{${escBib(p.publisher || 'Preprint')}}`]);
    f.push(['url', `{${p.link}}`]);
  } else if (kindLabel === 'article') {
    kind = '@article';
    f.push(['journal', `{${escBib(venue)}}`]);
    if (p.arxivId) f.push(['eprint', `{${p.arxivId}}`]);
    f.push(['url', `{${p.link}}`]);
  } else {
    f.push(['booktitle', `{${escBib(venue)}}`]);
    if (p.arxivId) {
      f.push(['eprint', `{${p.arxivId}}`]);
      f.push(['archivePrefix', `{arXiv}`]);
    }
    f.push(['url', `{${p.link}}`]);
  }
  const indented = f.map(([k, v]) => `  ${k} = ${v}`).join(',\n');
  return `${kind}{${key},\n${indented}\n}`;
}
const bibtex = buildBib(paper);

const issueBody = [
  `**Paper title:** ${paper.title}`,
  `**Paper link:** ${paper.link}`,
  `**Source line:** ${paper.source === 'adjacent' ? 'adjacent.yaml' : 'papers.yaml'}#L${paper.sourceLine}`,
  '',
  '### What is incorrect or missing?',
  '<!-- Please describe the issue (e.g., wrong authors, wrong date, wrong publisher, missing keyword, broken link). -->',
  '',
].join('\n');

const reportUrl = `${REPO_URL}/issues/new?` + new URLSearchParams({
  title: `[Metadata] ${paper.title}`,
  body: issueBody,
  labels: 'metadata-correction',
  template: 'metadata-correction.yml',
}).toString();
---
<Base
  title={paper.title}
  description={seoDescription}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-[960px] px-6 pt-14 pb-16" itemscope itemtype="https://schema.org/ScholarlyArticle">

    <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] gap-x-16 gap-y-8">

      {/* Left rail — issue plate for the paper */}
      <aside class="lg:border-r border-paper-300 dark:border-ink-600 lg:pr-6 lg:sticky lg:top-6 lg:self-start">
        <nav class="mb-6" aria-label="Breadcrumb">
          <a class="action-link action-link--ghost" href={`${base}/`}><span class="font-mono">←</span>Index</a>
        </nav>

        <dl class="space-y-4 text-[13.5px]">
          {paper.phase && (
            <div>
              <dt class="meta-label">Phase</dt>
              <dd class="mt-1.5">
                <a class="block hover:underline underline-offset-[3px]" href={`${base}/?phase=${encodeURIComponent(paper.phase)}`} title={PHASE_HEADINGS[paper.phase]?.title ?? paper.phase}>
                  <span class="phase-badge tabular-nums">{PHASE_CODE[paper.phase] ?? '—'}</span>
                  <span class="block mt-1 text-[13px] text-ink-500 dark:text-ink-300">{PHASE_HEADINGS[paper.phase]?.title}</span>
                </a>
              </dd>
            </div>
          )}
          <div>
            <dt class="meta-label">Date</dt>
            <dd class="meta-value mt-0.5">{paper.date}</dd>
          </div>
          <div>
            <dt class="meta-label">Venue</dt>
            <dd class="meta-value mt-0.5">{paper.publisher || '—'}</dd>
          </div>
          <div>
            <dt class="meta-label">Theme</dt>
            <dd class="mt-1 flex flex-wrap gap-x-2 gap-y-1">
              {paper.envs.map((env) => (
                <a class="topic-marker" href={`${base}/?env=${encodeURIComponent(env)}`} title={env}>{ENV_EMOJI[env] ?? '—'}</a>
              ))}
            </dd>
          </div>
          <div>
            <dt class="meta-label">Institutions</dt>
            <dd class="text-[13.5px] text-ink-700 dark:text-ink-50 mt-0.5">{paper.institutions.join(', ') || '—'}</dd>
          </div>
          {paper.arxivId && (
            <div>
              <dt class="meta-label">arXiv</dt>
              <dd class="meta-value mt-0.5 tabular-nums">{paper.arxivId}</dd>
            </div>
          )}
        </dl>
      </aside>

      {/* Main column — paper detail */}
      <div>
        <p class="heading-eyebrow">Entry</p>

        <h1 class="kicker-lg mt-4 text-ink-700 dark:text-ink-50 leading-[1.12] max-w-[28ch]" itemprop="headline">
          <a href={paper.link} target="_blank" rel="noopener" class="hover:text-accent dark:hover:text-accent-dark transition-colors">{paper.title}</a>
        </h1>

        <p class="mt-5 text-[16px] text-ink-600 dark:text-ink-200 leading-relaxed max-w-[60ch]">{paper.authors.join(', ')}</p>

        {paper.tldr && (
          <section class="mt-10">
            <p class="meta-label">Synopsis</p>
            <p class="mt-2 text-[17px] leading-[1.7] text-ink-700 dark:text-ink-50 max-w-[60ch]">{paper.tldr}</p>
          </section>
        )}

        {paper.keywords.length > 0 && (
          <section class="mt-8">
            <p class="meta-label mb-2">Keywords</p>
            <p class="text-[14.5px] text-ink-600 dark:text-ink-200 flex flex-wrap gap-x-3 gap-y-1.5 max-w-[60ch]">
              {paper.keywords.map((kw) => (
                <a class="hover:text-accent dark:hover:text-accent-dark transition-colors" href={`${base}/?key=${encodeURIComponent(kw)}`}>
                  <span class="text-paper-400 dark:text-ink-600 mr-0.5">·</span>{kw}
                </a>
              ))}
            </p>
          </section>
        )}

        <section class="mt-10 pt-6 border-t border-paper-300 dark:border-ink-600 flex flex-wrap items-baseline gap-x-8 gap-y-3 text-[13px] font-mono uppercase tracking-[0.08em]">
          <a href={paper.link} target="_blank" rel="noopener" class="text-accent dark:text-accent-dark hover:underline underline-offset-[3px]">Open paper ↗</a>
          {paper.arxivId && (
            <a href={`https://arxiv.org/abs/${paper.arxivId}`} target="_blank" rel="noopener" class="text-ink-500 dark:text-ink-300 hover:text-accent dark:hover:text-accent-dark">arXiv ↗</a>
          )}
          <button
        type="button"
        id="copy-bib-btn"
        data-bib={bibtex}
        class="text-ink-500 dark:text-ink-300 hover:text-accent dark:hover:text-accent-dark"
        aria-label="Copy BibTeX to clipboard"
      >
        <span id="copy-bib-label">Copy BibTeX</span>
      </button>
      <a href={reportUrl} target="_blank" rel="noopener" class="text-ink-500 dark:text-ink-300 hover:text-accent dark:hover:text-accent-dark">Report issue ↗</a>
    </section>

    <script is:inline>
      (function () {
        var btn = document.getElementById('copy-bib-btn');
        var label = document.getElementById('copy-bib-label');
        if (!btn || !label) return;
        btn.addEventListener('click', function () {
          var bib = btn.getAttribute('data-bib') || '';
          var done = function () {
            label.textContent = 'BibTeX copied';
            setTimeout(function () { label.textContent = 'Copy BibTeX'; }, 1600);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(bib).then(done).catch(function () {
              // fallback
              var ta = document.createElement('textarea');
              ta.value = bib; document.body.appendChild(ta); ta.select();
              try { document.execCommand('copy'); done(); } finally { ta.remove(); }
            });
          } else {
            var ta = document.createElement('textarea');
            ta.value = bib; document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); done(); } finally { ta.remove(); }
          }
        });
      })();
    </script>

    {related.length > 0 && (
      <section class="mt-16">
        <p class="meta-label mb-4">Related entries</p>
        <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-4 list-none p-0 max-w-[60ch]">
          {related.map((p) => (
            <li class="border-t border-paper-300 dark:border-ink-600 pt-4">
              <a href={`${base}/papers/${p.slug}`} class="block hover:text-accent dark:hover:text-accent-dark transition-colors">
                <div class="font-display text-[16px] text-ink-700 dark:text-ink-50 leading-snug">{p.title}</div>
                <div class="mt-1.5 text-[12.5px] font-mono text-ink-400 dark:text-ink-300 uppercase tracking-[0.06em]">{p.date} · {p.publisher}</div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
      </div>
    </div>
  </article>
</Base>
