---
import Base from '../../layouts/Base.astro';
import PaperBrowser from '../../islands/PaperBrowser';
import { loadAllPapers } from '../../lib/parsePapers';
import { REPO_RAW_BLOB } from '../../lib/site';

const { canonical, adjacent } = loadAllPapers();
const all = [...canonical, ...adjacent];
const lite = all.map((p) => ({
  slug: p.slug, title: p.title, link: p.link,
  authors: p.authors, institutions: p.institutions,
  date: p.date, dateISO: p.dateISO, year: p.year, month: p.month,
  publisher: p.publisher, envs: p.envs, keywords: p.keywords,
  tldr: p.tldr, arxivId: p.arxivId, source: p.source, sourceLine: p.sourceLine,
  bibtex: p.bibtex, bibtexConfirmed: p.bibtexConfirmed, sources: p.sources,
}));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base
  title="Browse all human-AI coevolution papers"
  description={`Search and filter ${canonical.length}+ papers on human-AI coevolution by category, keyword, author, institution, year, and venue.`}
>
  <section class="mx-auto max-w-7xl px-6 pt-14 pb-10 reveal-stagger">
    <div class="mb-10 max-w-3xl">
      <p class="heading-eyebrow">Browse</p>
      <h1 class="display-lg mt-5 text-ink-700 dark:text-ink-50">All papers</h1>
      <p class="text-ink-600 dark:text-ink-200 mt-4 text-[15px] leading-relaxed">
        <span class="font-mono tabular-nums text-ink-700 dark:text-ink-50">{canonical.length}</span>
        canonical entries — search across titles, authors, institutions, TLDRs, and keywords; or filter by category, keyword, year, venue.
      </p>
    </div>

    <PaperBrowser client:only="solid-js" papers={lite} basePath={base} repoBlobUrl={REPO_RAW_BLOB} />
    <noscript>
      <div class="surface rounded-md p-6 mt-4 text-sm text-ink-600 dark:text-ink-100">
        The interactive browser needs JavaScript. You can still view the
        <a class="link" href="https://github.com/xli04/Awesome-Human-AI-Coevolution-Paper-List/blob/main/papers.yaml">full structured list on GitHub</a>.
      </div>
    </noscript>
  </section>
</Base>
